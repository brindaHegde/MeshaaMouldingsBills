<Window x:Class="InvoicePrint.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvoicePrint"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="Tax Invoice" Height="600" Width="900" Icon="/Imgs/MeshaaMouldingsLogo.png">
    <Window.Resources>
        <!-- Common Border Style -->
        <Style x:Key="CommonBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="CommonTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="0 0 0 1"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>

        <Style x:Key="CommonButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="Blue"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <ScrollViewer Margin="10" Padding="10">
            <Grid x:Name="TaxInvoice" Width="794" Height="1123" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding CopyName, Mode=TwoWay}" Padding="5" FontWeight="ExtraBold" FontSize="18" TextAlignment="Center"/>
                <Border Grid.Row="1" Style="{StaticResource CommonBorderStyle}" BorderThickness="1 1 1 0" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="80"/>
                            <RowDefinition Height="140"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="90"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.5*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.ColumnSpan="3" Style="{StaticResource CommonBorderStyle}" >
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="/Imgs/MeshaaMouldingsLogo.png" Height="70" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1" Text="TAX INVOICE / LABOUR BILL" TextAlignment="Center" FontWeight="ExtraBold" FontSize="20"/>
                                <TextBlock Grid.Column="2" Text="#576 (49/18), 16th A Cross, Muthuraya Swamy Layout, Magadi Main Road, Sunkadakatte, Bengaluru - 560091 meshaamouldings@gmail.com" TextWrapping="Wrap" FontSize="12"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource CommonBorderStyle}" BorderThickness="1 0 1 1">
                            <Grid Grid.Row="1" Grid.ColumnSpan="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="18"/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Buyer's Name and Address:" Grid.ColumnSpan="2" FontWeight="Bold"/>
                                <TextBlock Text="Name" Grid.Row="1" VerticalAlignment="Center"/>
                                <TextBlock Text="Address" Grid.Row="2" VerticalAlignment="Center"/>
                                <TextBlock Text="GSTIN" Grid.Row="4" VerticalAlignment="Center"/>

                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource CommonTextBoxStyle}" Text="{Binding BuyerDetails.BuyerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="LostFocus">
                                            <i:InvokeCommandAction Command="{Binding BuyerNameLostFocus}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </TextBox>
                                <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource CommonTextBoxStyle}" Text="{Binding BuyerDetails.BuyerAddress1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource CommonTextBoxStyle}" Text="{Binding BuyerDetails.BuyerAddress2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource CommonTextBoxStyle}" Text="{Binding BuyerDetails.BuyerGSTIN, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource CommonBorderStyle}" BorderThickness="0 0 1 1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="INVOICE NO.: " VerticalAlignment="Bottom"/>
                                    <TextBox Style="{StaticResource CommonTextBoxStyle}" Width="130" Text="{Binding InvoiceDetails.InvoiceNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="LostFocus">
                                                <i:InvokeCommandAction Command="{Binding InvoiceNumLostFocus}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </TextBox>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <TextBlock Text="Date: " VerticalAlignment="Bottom"/>
                                    <TextBox Style="{StaticResource CommonTextBoxStyle}" Width="170" Text="{Binding InvoiceDetails.InvoiceDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Time: " VerticalAlignment="Bottom"/>
                                        <TextBox Style="{StaticResource CommonTextBoxStyle}" Width="75" Text="{Binding InvoiceDetails.InvoiceTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="Bags: " VerticalAlignment="Bottom"/>
                                        <TextBox Style="{StaticResource CommonTextBoxStyle}" Width="75" Text="{Binding InvoiceDetails.Bags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="GSTIN : 29AAJFM0207E1ZM" Grid.Row="3" FontWeight="Bold" FontSize="16" VerticalAlignment="Bottom"/>
                                <TextBlock Text="State Code : KARNATAKA 29" Grid.Row="4" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource CommonBorderStyle}" BorderThickness="1 0 1 1">
                            <DataGrid ItemsSource="{Binding GoodsList}" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="false"
                                  CanUserDeleteRows="True"
                                  IsReadOnly="False" ColumnWidth="auto"
                                  RowBackground="White" RowHeight="30" VerticalContentAlignment="Center">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="SlNo" Binding="{Binding SlNo, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Header="HSN Code" Binding="{Binding HSNCode, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Description" Width="3*" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Qty" Width="100" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Rate" Width="100" Binding="{Binding Rate, UpdateSourceTrigger=PropertyChanged}" />
                                    <DataGridTextColumn Header="Amount" Width="*" Binding="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>


                        <Grid Grid.Row="3" Grid.ColumnSpan="2" >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource CommonBorderStyle}" BorderThickness="1 0 1 1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Dispatched by: "/>
                                    <TextBox BorderThickness="0" Text="{Binding DispatchedBy}" MinWidth="100"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CommonBorderStyle}" BorderThickness="0 0 1 1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="E-way No.: "/>
                                    <TextBox BorderThickness="0" Text="{Binding EWayNo}" MinWidth="100"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="3" Grid.RowSpan="3" Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CommonBorderStyle}" BorderThickness="0 0 1 1">
                                <TextBlock Text="Sub Total: " FontWeight="Bold"/>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CommonBorderStyle}" BorderThickness="0 0 1 1">
                                <TextBox Text="{Binding SubTotal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CommonTextBoxStyle}" BorderThickness="0">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="GotFocus">
                                            <i:InvokeCommandAction Command="{Binding SubTotalGotFocus}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </TextBox>
                            </Border>

                            <Border Style="{StaticResource CommonBorderStyle}" Grid.Row="1" BorderThickness="0 0 1 1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="CGST " VerticalAlignment="Bottom"/>
                                    <TextBox x:Name="cgst" Width="30" Style="{StaticResource CommonTextBoxStyle}" Text="{Binding CGSTVal, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="%" VerticalAlignment="Bottom"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CommonBorderStyle}" Grid.Row="1" Grid.Column="1" BorderThickness="0 0 1 1">
                                <TextBox Text="{Binding CGSTCalcVal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CommonTextBoxStyle}" BorderThickness="0"/>
                            </Border>


                            <Border Style="{StaticResource CommonBorderStyle}" Grid.Row="2" BorderThickness="0 0 1 1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="SGST " VerticalAlignment="Bottom"/>
                                    <TextBox x:Name="sgst" Width="30" Style="{StaticResource CommonTextBoxStyle}" Text="{Binding SGSTVal, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="%" VerticalAlignment="Bottom"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CommonBorderStyle}" Grid.Row="2" Grid.Column="1" BorderThickness="0 0 1 1">
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SGSTCalcVal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CommonTextBoxStyle}" BorderThickness="0"/>
                            </Border>

                            <Border Style="{StaticResource CommonBorderStyle}" Grid.Row="3" BorderThickness="0 0 1 1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="IGST " VerticalAlignment="Bottom"/>
                                    <TextBox Width="30" Style="{StaticResource CommonTextBoxStyle}" Text="{Binding IGSTVal, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="%" VerticalAlignment="Bottom"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CommonBorderStyle}" Grid.Row="3" Grid.Column="1" BorderThickness="0 0 1 1">
                                <TextBox Text="{Binding IGSTCalcVal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CommonTextBoxStyle}" BorderThickness="0"/>
                            </Border>

                            <Border Style="{StaticResource CommonBorderStyle}" Grid.Row="4" BorderThickness="0 0 1 1">
                                <TextBlock Text="G. Total" FontWeight="Bold" FontSize="16"/>
                            </Border>
                            <Border Style="{StaticResource CommonBorderStyle}" Grid.Row="4" Grid.Column="1"  BorderThickness="0 0 1 1">
                                <TextBox Text="{Binding GrandTotal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CommonTextBoxStyle}" BorderThickness="0"/>
                            </Border>

                        </Grid>


                        <Grid Grid.Row="4" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource CommonBorderStyle}" BorderThickness="1 0 1 1" Padding="0">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="Purchase Order No.: " Padding="5"/>
                                    <Border Style="{StaticResource CommonBorderStyle}" BorderThickness="0 1 0 0">
                                        <TextBox BorderThickness="0" Text="{Binding PurchaseOrd}" MinWidth="100"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CommonBorderStyle}" BorderThickness="0 0 1 1" Padding="0">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="DC No.: " Padding="5"/>
                                    <Border Style="{StaticResource CommonBorderStyle}" BorderThickness="0 1 0 0">
                                        <TextBox BorderThickness="0" Text="{Binding DCNo}" MinWidth="100"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>


                        <Border Grid.Row="5" Grid.ColumnSpan="2" Style="{StaticResource CommonBorderStyle}" BorderThickness="1 0 1 1">
                            <TextBox AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="{Binding StrGTotal}" BorderThickness="0" FontSize="15"/>
                        </Border>

                        <Grid Grid.Row="6" Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Border Style="{StaticResource CommonBorderStyle}" Grid.Row="0" BorderThickness="1 0 1 1">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="Terms and Conditions : "/>
                                        <TextBlock Text="Subjected to Bangalore Jurisdiction"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource CommonBorderStyle}" BorderThickness="1 0 1 1">
                                    <TextBox BorderThickness="0"/>
                                </Border>
                                <Border Grid.Row="2" Style="{StaticResource CommonBorderStyle}" BorderThickness="1 0 1 1" >
                                    <TextBlock Text="Receiver's Signature"/>
                                </Border>
                            </Grid>

                            <Border Grid.Column="1" Style="{StaticResource CommonBorderStyle}" Grid.Row="0" BorderThickness="0 0 1 1">
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="Bank Details : (Optional) SBI" FontWeight="Bold" FontSize="15"/>
                                    <TextBlock Text="Bank Account Number : 64083020944" FontSize="15"/>
                                    <TextBlock Text="Bank Branch : Vinayaka Layout" FontSize="15"/>
                                    <TextBlock Text="Bank Branch IFSC : SBIN0040790" FontSize="15"/>
                                    <TextBlock Text="Micr Code : 56002510" FontSize="15"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="2" Orientation="Vertical">
                                <Border Style="{StaticResource CommonBorderStyle}" BorderThickness="0 0 1 1">
                                    <TextBlock Text="For Meshaa Mouldings" FontWeight="Bold" FontSize="18" TextAlignment="Center"/>
                                </Border>
                                <Border Style="{StaticResource CommonBorderStyle}" BorderThickness="0 0 1 0">
                                    <TextBox BorderThickness="0" Height="70"/>
                                </Border>
                                <Border Style="{StaticResource CommonBorderStyle}" BorderThickness="0 0 1 1">
                                    <TextBlock Text="Partner" TextAlignment="Center"/>
                                </Border>
                            </StackPanel>


                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Style="{StaticResource CommonButtonStyle}" Content="Open Invoice" Command="{Binding PrintButton}" CommandParameter="{Binding ElementName=TaxInvoice}"/>
            <Button Style="{StaticResource CommonButtonStyle}" Content="Save Invoice" Command="{Binding PrintButton}" CommandParameter="{Binding ElementName=TaxInvoice}"/>
            <Button Style="{StaticResource CommonButtonStyle}" Content="Print Invoice" Command="{Binding PrintButton}" CommandParameter="{Binding ElementName=TaxInvoice}"/>
        </StackPanel>

    </Grid>
</Window>
